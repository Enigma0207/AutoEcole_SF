{% extends 'base.html.twig' %}

{% block title %}Creneaux{% endblock %}

{% block body %}
    <h1>Creneaux</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ creneaux.id }}</td>
            </tr>
            <tr>
                <th>Date</th>
                <td>{{ creneaux.date ? creneaux.date|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>IsAvailable</th>
                <td>{{ creneaux.isAvailable ? 'Yes' : 'No' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_creneaux_index') }}">back to list</a>

    <a href="{{ path('app_creneaux_edit', {'id': creneaux.id}) }}">edit</a>

    {{ include('creneaux/_delete_form.html.twig') }}
{% endblock %}
